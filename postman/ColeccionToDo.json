{
  "info": {
    "name": "API ToDoApp",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST crear tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201 Created\", () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Respuesta contiene id numerico\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b).to.have.property('id');",
              "  pm.collectionVariables.set('tareaId', b.id);",
              "});",
              "pm.test(\"Tiempo de respuesta < 500ms\", () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Tarea Postman\",\n  \"descripcion\": \"Creada desde Postman\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tareas",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tareas"
          ]
        }
      }
    },
    {
      "name": "GET obtener tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Contiene id\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b).to.have.property('id');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/tareas/{{tareaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tareas",
            "{{tareaId}}"
          ]
        }
      }
    },
    {
      "name": "PATCH completar tarea",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Tarea completada\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.completada).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "url": {
          "raw": "{{baseUrl}}/api/tareas/{{tareaId}}/completar",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tareas",
            "{{tareaId}}",
            "completar"
          ]
        }
      }
    },
    {
      "name": "GET verificar completada",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Completada en true\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.completada).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/tareas/{{tareaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tareas",
            "{{tareaId}}"
          ]
        }
      }
    },
    {
      "name": "GET tarea inexistente (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 404 Not Found\", () => {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/tareas/999999",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tareas",
            "999999"
          ]
        }
      }
    }
  ]
}
